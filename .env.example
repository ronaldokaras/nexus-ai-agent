# ==============================================
# Nexus Agent - Environment Variables (example)
# Copie este arquivo para .env e preencha com seus dados
# ==============================================

# ---------- API Keys ----------
# OpenRouter API Key (obtenha em https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-sua-chave-aqui

# ---------- Model Configuration ----------
# Modelo LLM a ser utilizado via OpenRouter
# Exemplos: google/gemini-2.0-flash-001, anthropic/claude-3-haiku, openai/gpt-4o-mini
MODEL_ID=google/gemini-2.0-flash-001

# Temperatura (0.0 = determinístico, 1.0 = criativo)
TEMPERATURE=0.90

# Número máximo de mensagens no histórico de conversa
MAX_HISTORY=30

# ---------- Voice (ElevenLabs) - Opcional ----------
# Habilita voz via ElevenLabs (true/false)
USE_ELEVENLABS_VOICE=false

# ElevenLabs API Key (obtenha em https://elevenlabs.io/app/settings/api-keys)
ELEVENLABS_API_KEY=sk-sua-chave-elevenlabs

# ID da voz padrão (opcional)
ELEVENLABS_VOICE_ID=cgSgspJ2msm6clMCkdW9

# Habilita voz na inicialização (true/false)
VOICE_ENABLED=false

# ---------- Offline TTS (pyttsx3) - Opcional ----------
# Velocidade da fala offline (padrão: 172)
TTS_OFFLINE_RATE=172

# Volume da fala offline (0.0 a 1.0)
TTS_OFFLINE_VOLUME=0.95

# ---------- Speech-to-Text (STT) - Opcional ----------
# Duração padrão de escuta em segundos
LISTEN_DURATION=5.5

# Taxa de amostragem do microfone
LISTEN_SAMPLE_RATE=16000